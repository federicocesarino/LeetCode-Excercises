WITH valid_trips AS (
    SELECT
        t.request_at AS day,
        t.status
    FROM Trips t
    JOIN Users c ON t.client_id = c.users_id AND c.banned = 'No'
    JOIN Users d ON t.driver_id = d.users_id AND d.banned = 'No'
    WHERE t.request_at BETWEEN '2013-10-01' AND '2013-10-03'
),

cancelled_by_day AS (
    SELECT
        day,
        COUNT(*) AS cancelled_count
    FROM valid_trips
    WHERE (status = 'cancelled_by_client' OR status = 'cancelled_by_driver')
    GROUP BY day
),

total_by_day AS (
    SELECT
        day,
        COUNT(*) AS total_count
    FROM valid_trips
    GROUP BY day
)

SELECT
    day AS Day,
    ROUND(COALESCE(cancelled_count, 0) / total_count, 2) AS `Cancellation Rate`
FROM total_by_day
LEFT JOIN cancelled_by_day USING (day);
